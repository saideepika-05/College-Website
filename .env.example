# --- Database (Neon) ---
# Pooled connection string (use for the app):
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/college_erp?sslmode=require
# Direct (non-pooled) connection string (used only for migrations):
DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/college_erp?sslmode=require

# --- Auth ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# --- Attendance QR ---
# Generate with: openssl rand -base64 32  (must differ from BETTER_AUTH_SECRET)
ATTENDANCE_QR_SECRET=

# --- Cron ---
# Shared secret for Vercel Cron route handlers.
CRON_SECRET=

# --- App ---
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
